# Default: use LF
* text=auto eol=lf

# Explicitly enforce LF for source files
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.json text eol=lf

# Windows scripts can stay CRLF if you ever add them
*.ps1 text eol=crlf
*.bat text eol=crlf

# Binary files (no normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary